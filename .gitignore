### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-file
*.flf
#Test results file
TestResults.xml
#Ignore .env files
.env
#Ignore wordpress directories and files
wordpress/

# SSL certificates — never commit private keys
certs/privkey.pem
certs/fullchain.pem
certs/*.pem
certs/*.crt
certs/*.key

# Log files — ignore content, not the directories themselves
logs/nginx/*.log
logs/nginx/*.log-*
logs/nginx/*.log.gz
logs/mysql/*.log
logs/mysql/*.log-*
logs/mysql/*.log.gz

# Nginx log rotation — runs inside the nginx container.
#
# Installed to /etc/logrotate.d/c2-nginx by bin/Dockerfile.nginx.
# Triggered hourly by /etc/cron.d/c2-nginx-logrotate (also in the image).
#
# Rotates access.log and error.log when they reach 10 MB.
# Keeps the last 3 rotated files; older files are deleted automatically.
# postrotate sends `nginx -s reopen` directly — no docker exec needed from
# inside the container.

/var/log/nginx/*.log {
    size    10M
    rotate  3
    missingok
    notifempty
    compress
    delaycompress
    dateext
    dateformat -%Y%m%d
    sharedscripts
    postrotate
        nginx -s reopen 2>/dev/null || true
    endscript
}
